// Template for local secrets.
// Copy this file to `Secrets.xcconfig` and fill in real values.
// `Secrets.xcconfig` is gitignored so tokens never get committed.
HF_TOKEN =
PLACES_API_KEY =
// Supabase backend. SUPABASE_REF is just the project ref (the xxxx in
// https://xxxx.supabase.co) — we store the ref, not the full URL, because "//"
// starts a comment in xcconfig. SUPABASE_ANON_KEY is the publishable key.
SUPABASE_REF =
SUPABASE_ANON_KEY =
// Shared token gating the backend Edge Functions. Must match the APP_TOKEN
// Supabase secret (supabase secrets set APP_TOKEN=...).
APP_TOKEN =
