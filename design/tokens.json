{
  "$description": "Brightglow design tokens — single source of truth shared across Figma (Tokens Studio), Xcode (Style Dictionary), and code. Edit here; mirror outward.",
  "color": {
    "bg":            { "$type": "color", "$value": "#131315" },
    "cardFallback":  { "$type": "color", "$value": "#1E1E22" },
    "accentStart":   { "$type": "color", "$value": "#0039F5" },
    "accentEnd":     { "$type": "color", "$value": "#1528FF" },
    "ctaBlue":       { "$type": "color", "$value": "#617AFF" },
    "ctaSecondary":  { "$type": "color", "$value": "#333640" },
    "textPrimary":   { "$type": "color", "$value": "#FFFFFF" },
    "textSecondary": { "$type": "color", "$value": "#FFFFFF80" },
    "starFilled":    { "$type": "color", "$value": "#D3A500" },
    "starEmpty":     { "$type": "color", "$value": "#FFFFFF33" },
    "dotActive":     { "$type": "color", "$value": "#FFFFFF" },
    "dotInactive":   { "$type": "color", "$value": "#FFFFFF4D" },
    "border":        { "$type": "color", "$value": "#FFFFFF1F" }
  },
  "gradient": {
    "accent": {
      "$type": "gradient",
      "$value": [
        { "color": "#0039F5", "position": 0 },
        { "color": "#1528FF", "position": 1 }
      ]
    }
  },
  "font": {
    "family": {
      "heading": { "$type": "fontFamily", "$value": "Lato" },
      "body":    { "$type": "fontFamily", "$value": "Poppins" }
    },
    "weight": {
      "extrabold": { "$type": "fontWeight", "$value": 800 },
      "bold":      { "$type": "fontWeight", "$value": 700 },
      "light":     { "$type": "fontWeight", "$value": 300 }
    }
  },
  "typography": {
    "h1":        { "$type": "typography", "$value": { "fontFamily": "Lato",    "fontWeight": 800, "fontSize": 44 } },
    "h2":        { "$type": "typography", "$value": { "fontFamily": "Lato",    "fontWeight": 800, "fontSize": 24 } },
    "h3":        { "$type": "typography", "$value": { "fontFamily": "Lato",    "fontWeight": 700, "fontSize": 18 } },
    "h4":        { "$type": "typography", "$value": { "fontFamily": "Lato",    "fontWeight": 700, "fontSize": 14 } },
    "bodyLight": { "$type": "typography", "$value": { "fontFamily": "Poppins", "fontWeight": 300, "fontSize": 17 } },
    "bodySmall": { "$type": "typography", "$value": { "fontFamily": "Poppins", "fontWeight": 300, "fontSize": 14 } }
  },
  "radius": {
    "card":   { "$type": "dimension", "$value": 32 },
    "button": { "$type": "dimension", "$value": 32 }
  },
  "size": {
    "buttonHeight": { "$type": "dimension", "$value": 56 },
    "dot":          { "$type": "dimension", "$value": 8 }
  },
  "space": {
    "1": { "$type": "dimension", "$value": 4 },
    "2": { "$type": "dimension", "$value": 8 },
    "3": { "$type": "dimension", "$value": 12 },
    "4": { "$type": "dimension", "$value": 16 },
    "5": { "$type": "dimension", "$value": 20 },
    "6": { "$type": "dimension", "$value": 24 },
    "7": { "$type": "dimension", "$value": 28 },
    "8": { "$type": "dimension", "$value": 32 }
  }
}
